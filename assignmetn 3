import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Load Dataset
df = pd.read_csv("sales_data.csv")

# Statistical Summary
print(df.describe())

# Missing Values
print(df.isnull().sum())

# Histogram
sns.histplot(df['Sales'],
             kde=True)

plt.show()

# Scatter Plot
sns.scatterplot(
    x='Advertising',
    y='Sales',
    data=df
)

plt.show()

# Correlation Heatmap
sns.heatmap(
    df.corr(numeric_only=True),
    annot=True,
    cmap='coolwarm'
)

plt.show()
